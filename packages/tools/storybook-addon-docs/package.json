{
  "name": "@momentum-design/storybook-addon-docs",
  "packageManager": "yarn@3.2.4",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=8.0.0"
  },
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js",
      "require": "./dist/preview.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "analyze": "yarn analyze:prebuild && yarn analyze:postbuild",
    "analyze:postbuild": "echo \"script 'analyze:postbuild' has not been implemented\"",
    "analyze:prebuild": "tsc --noEmit",
    "build": "tsup",
    "build:watch": "npm run build -- --watch",
    "test": "yarn test:prebuild && yarn test:postbuild",
    "test:postbuild": "echo \"script 'test:postbuild' has not been implemented\"",
    "test:prebuild": "echo \"script 'test:prebuild' has not been implemented\"",
    "start": "concurrently \"npm:build:watch\" \"npm run storybook -- --quiet\"",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "clean": "rimraf ./dist",
    "publish": "yarn publish:npmjs",
    "publish:npmjs": "echo \"script 'publish:npmjs' has not been implemented\""
  },
  "dependencies": {
    "markdown-to-jsx": "^7.5.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^9.1.5",
    "@storybook/react-vite": "^9.1.5",
    "@types/node": "20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^10.0.3",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "storybook": "^9.1.5",
    "tsup": "^8.2.4",
    "typescript": "^5.9.2",
    "vite": "^5.4.0"
  },
  "peerDependencies": {
    "@momentum-design/components": "workspace:^",
    "@storybook/addon-docs": "^9.1.5",
    "react": "^18.0.0",
    "storybook": "^9.1.5"
  },
  "bundler": {
    "exportEntries": [
      "src/index.ts"
    ],
    "previewEntries": [
      "src/preview.tsx"
    ]
  }
}
