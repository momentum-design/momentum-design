{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/AnimationFile",
  "definitions": {
    "AnimationFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "animation": {
          "$ref": "#/definitions/AnimationMap"
        }
      },
      "required": ["animation"],
      "title": "AnimationFile"
    },
    "AnimationMap": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9]*$": {
          "$ref": "#/definitions/AnimationToken"
        }
      },
      "additionalProperties": false,
      "title": "AnimationMap"
    },
    "AnimationToken": {
      "type": "object",
      "required": ["description", "type", "duration", "easing", "delay"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["transition", "keyframe", "compoundTransitions", "compoundKeyframes"]
        },
        "duration": { "type": "string" },
        "easing": { "type": "string" },
        "delay": { "type": "string" },
        "properties": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "keyframes": {
          "type": "array",
          "items": { "$ref": "#/definitions/KeyframeEntry" },
          "minItems": 1
        },
        "animations": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "composition": {
          "type": "string",
          "enum": ["parallel", "sequential"]
        },
        "iterationCount": {
          "oneOf": [
            { "type": "string", "const": "infinite" },
            { "type": "number", "minimum": 1 }
          ]
        },
        "fillMode": {
          "type": "string",
          "enum": ["none", "forwards", "backwards", "both"]
        }
      },
      "title": "AnimationToken"
    },
    "KeyframeEntry": {
      "type": "object",
      "required": ["propertyName", "from", "to"],
      "additionalProperties": false,
      "properties": {
        "propertyName": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" }
      },
      "title": "KeyframeEntry"
    }
  }
}

