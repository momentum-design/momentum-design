{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/AnimationFile",
  "definitions": {
    "TokenRef": {
      "type": "string",
      "pattern": "^\\{[a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)+\\}$"
    },
    "TokenIdentifier": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9]*$"
    },
    "CssAnimatableProperty": {
      "type": "string",
      "enum": [
        "background-color",
        "border-color",
        "border-radius",
        "border-width",
        "box-shadow",
        "clip-path",
        "color",
        "filter",
        "font-size",
        "gap",
        "height",
        "letter-spacing",
        "max-height",
        "max-width",
        "opacity",
        "outline",
        "rotate",
        "scale",
        "transform",
        "translate",
        "visibility",
        "width"
      ]
    },
    "AnimationFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "animation": {
          "$ref": "#/definitions/AnimationMap"
        }
      },
      "required": ["animation"],
      "title": "AnimationFile"
    },
    "AnimationMap": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9]*$": {
          "$ref": "#/definitions/AnimationToken"
        }
      },
      "additionalProperties": false,
      "title": "AnimationMap"
    },
    "AnimationToken": {
      "type": "object",
      "required": ["description", "type", "duration", "easing", "delay"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["transition", "keyframe", "compoundTransitions", "compoundKeyframes"]
        },
        "duration": { "$ref": "#/definitions/TokenRef" },
        "easing": { "$ref": "#/definitions/TokenRef" },
        "delay": { "$ref": "#/definitions/TokenRef" },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/definitions/CssAnimatableProperty" },
          "minItems": 1
        },
        "keyframes": {
          "type": "array",
          "items": { "$ref": "#/definitions/KeyframeEntry" },
          "minItems": 1
        },
        "animations": {
          "type": "array",
          "items": { "$ref": "#/definitions/TokenIdentifier" },
          "minItems": 1
        },
        "composition": {
          "type": "string",
          "enum": ["parallel", "sequential"]
        },
        "iterationCount": {
          "oneOf": [
            { "type": "string", "const": "infinite" },
            { "type": "number", "minimum": 1 }
          ]
        },
        "fillMode": {
          "type": "string",
          "enum": ["none", "forwards", "backwards", "both"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "transition" } },
            "required": ["type"]
          },
          "then": {
            "required": ["properties"],
            "properties": {
              "keyframes": false,
              "iterationCount": false,
              "fillMode": false,
              "animations": false,
              "composition": false
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "keyframe" } },
            "required": ["type"]
          },
          "then": {
            "required": ["keyframes"],
            "properties": {
              "properties": false,
              "animations": false,
              "composition": false
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "compoundTransitions" } },
            "required": ["type"]
          },
          "then": {
            "required": ["animations", "composition"],
            "properties": {
              "properties": false,
              "keyframes": false,
              "iterationCount": false,
              "fillMode": false
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "compoundKeyframes" } },
            "required": ["type"]
          },
          "then": {
            "required": ["animations"],
            "properties": {
              "properties": false,
              "keyframes": false,
              "iterationCount": false,
              "fillMode": false
            }
          }
        }
      ],
      "title": "AnimationToken"
    },
    "KeyframeEntry": {
      "type": "object",
      "required": ["propertyName", "from", "to"],
      "additionalProperties": false,
      "properties": {
        "propertyName": { "$ref": "#/definitions/CssAnimatableProperty" },
        "from": { "type": "string" },
        "to": { "type": "string" }
      },
      "title": "KeyframeEntry"
    }
  }
}

